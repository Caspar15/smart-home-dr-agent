# ===== ML caches & large artifacts (regenerable) =====
# NOTE: gitignore does NOT support inline comments — keep patterns on their own line.
# Regenerate via: pre_cache (parquet) / train_all (.pt) / rollout (.npz)
cache/
multi_household/cache/
multi_household/models/
*.npz
*.pt
*.pth
*.parquet
*.h5
*.ckpt
*.joblib
*.pkl

# ===== Slide QA renders (regenerable PNG dumps from PowerPoint) =====
# we don't track slide previews — re-render from the build scripts
slides/render_*/
**/slide_render*/

# ===== OS / editor =====
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~

# ===== Optional: dataset (public UCI; uncomment to exclude) =====
# Dataset lives in ../dataset/ relative to this folder.
# ../dataset/
# *.csv

# ===== Kept on purpose (do NOT ignore) =====
# results/         -> metrics CSVs (small, paper deliverables)
# figures/         -> paper figures (PNG)
# slides/assets/   -> source slide figures (PNG, hand-made)
# reports/         -> LLM advisory + metrics outputs
# docs/, src/, experiments/, *.md, requirements.txt
